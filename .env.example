# PostgreSQL Database (TrueNAS)
PG_HOST="100.88.85.6"
PG_PORT="5432"
PG_USER="admin"
PG_PASSWORD="your_postgres_password"
PG_DATABASE="portfolio"

# JWT Secret for admin authentication
# Auto-generated at runtime if not set, but set a stable one for production
JWT_SECRET="your-jwt-secret-here"

# Hostinger FTP Configuration
# You can find these in your Hostinger Panel -> Files -> FTP Accounts
# Example: 82.112.228.8
FTP_HOST="ftp.yourdomain.com"
# Example: u844765482.wheat-panther-882734.hostingersite.com
FTP_USER="your_ftp_username"
FTP_PASSWORD="your_ftp_password"
FTP_REMOTE_PATH="/public_html/gallery"

# The public URL where your Hostinger images are served
# Example: https://wheat-panther-882734.hostingersite.com/gallery
IMAGE_BASE_URL="https://yourdomain.com/gallery"

# GEMINI_API_KEY: Required for Gemini AI API calls (optional)
GEMINI_API_KEY=""
